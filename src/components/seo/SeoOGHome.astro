---
/**
 * src/components/seo/SeoOGHome.astro
 * OG meta tags for the Home page
 */
import SeoOG from './SeoOG.astro';
import homeEn from '../../locales/pages/home/en.json';

interface Props { lang?: 'en' | 'ru'; }
const { lang = 'en' } = Astro.props;

const locale = lang === 'en' ? homeEn : (await import('../../locales/pages/home/ru.json')).default;
const title       = locale.meta?.title || 'Home';
const description = locale.meta?.description || '';
const url         = `${import.meta.env.PUBLIC_DOMAIN}/`;
---

<SeoOG title={title} description={description} url={url} />
