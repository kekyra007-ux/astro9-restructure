---
interface Strategy {
  title: string;
  text:  string;
  tag:   string;
}

interface Tip {
  icon:  string;
  title: string;
  text:  string;
}

interface Props {
  heading:    string;
  subtitle:   string;
  strategies: Strategy[];
  tips:       Tip[];
}

const { heading, subtitle, strategies, tips } = Astro.props;
---

<section class="strategies">
  <div class="strategies__inner">

    <h2 class="strategies__heading">{heading}</h2>
    <p class="strategies__subtitle">{subtitle}</p>

    <div class="strategies__grid">
      {strategies.map((s) => (
        <div class="strategies__card">
          <span class="strategies__tag">{s.tag}</span>
          <h3 class="strategies__card-title">{s.title}</h3>
          <p class="strategies__card-text">{s.text}</p>
        </div>
      ))}
    </div>

    <div class="strategies__tips">
      {tips.map((tip) => (
        <div class="strategies__tip">
          <span class="strategies__tip-icon">{tip.icon}</span>
          <div>
            <p class="strategies__tip-title">{tip.title}</p>
            <p class="strategies__tip-text">{tip.text}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .strategies {
    background: var(--color-surface-alt, #F8FAFC);
    padding: 5rem 0;
  }

  .strategies__inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--container-pad);
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .strategies__heading {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3.5vw, 2.2rem);
    font-weight: 800;
    color: var(--color-text);
    text-align: center;
    line-height: 1.2;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .strategies__subtitle {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    text-align: center;
    line-height: 1.75;
    max-width: 760px;
    margin: -1.5rem auto 0;
  }

  .strategies__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  .strategies__card {
    background: #FFFFFF;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-lg, 12px);
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    box-shadow: var(--shadow-sm);
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .strategies__card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-indigo);
  }

  .strategies__tag {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background: #EEF2FF;
    color: var(--color-primary);
    border: 1px solid #C7D2FE;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 600;
    align-self: flex-start;
  }

  .strategies__card-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
    line-height: 1.4;
  }

  .strategies__card-text {
    font-size: 0.87rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin: 0;
  }

  /* Tips row */
  .strategies__tips {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1rem;
  }

  .strategies__tip {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    background: #FFFFFF;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-lg, 12px);
    padding: 1.25rem;
    box-shadow: var(--shadow-sm);
  }

  .strategies__tip-icon {
    font-size: 1.25rem;
    flex-shrink: 0;
    line-height: 1;
    margin-top: 2px;
  }

  .strategies__tip-title {
    font-size: 0.87rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 0.3rem;
  }

  .strategies__tip-text {
    font-size: 0.82rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 640px) {
    .strategies__grid,
    .strategies__tips {
      grid-template-columns: 1fr;
    }
  }
</style>
