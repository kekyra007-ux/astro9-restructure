---
/**
 * FAQ.astro — Accordion FAQ section.
 *
 * Design (from screenshots / CSS):
 *   • Centered H2
 *   • Stacked accordion items: dark question row + hidden answer
 *   • Expand/collapse with +/− icon (client JS)
 *   • Max-width: 1280px
 *
 * Props:
 *   heading  string               — section H2
 *   items    Array<{ question, answer }>
 */

interface FaqItem { question: string; answer: string; }

interface Props {
  heading?: string;
  items:    FaqItem[];
}

const {
  heading = 'Frequently Asked Questions',
  items,
} = Astro.props;
---

<section class="faq-section">
  <div class="faq_sec">
    <h2>{heading}</h2>

    <div class="faq_container">
      {items.map(({ question, answer }, i) => (
        <div class="faq_item">
          <button
            class="faq_question"
            aria-expanded="false"
            aria-controls={`faq-answer-${i}`}
          >
            {question}
          </button>
          <div class="faq_answer" id={`faq-answer-${i}`} role="region">
            <p>{answer}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
.faq-section {
  background-color: var(--page-bg);
  padding: 20px 0 40px;
}

.faq_sec {
  color: var(--color-text);
  padding: 40px;
  max-width: 1280px;
  margin: 0 auto;
  border-radius: var(--border-radius, 10px);
}

.faq_sec h2 {
  margin: 0 auto 48px;
    font-size: clamp(1.5rem, 1.2rem + 1.6vw, 2rem);
    font-weight: 700;
    line-height: 1.02;
    letter-spacing: -0.045em;
  color: #0f172a;
  text-align: center;
  text-transform: none;
  text-wrap: balance;
}

.faq_container {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.faq_item {
  border: 1px solid var(--color-border);
  border-radius: 5px;
  overflow: hidden;
}

.faq_question {
  width: 100%;
  text-align: left;
  padding: 15px 50px 15px 15px;
  background: var(--color-surface);
  color: var(--color-text);
  font-family: var(--font-family);
  font-size: 20px;
  border: none;
  cursor: pointer;
  position: relative;
  transition: background .2s ease;
}

.faq_question::after {
  content: "+";
  position: absolute;
  right: 20px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 22px;
  font-weight: 300;
  transition: transform .3s ease;
}

.faq_question[aria-expanded="true"] { background: var(--color-surface-alt); }
.faq_question[aria-expanded="true"]::after { content: "−"; }

.faq_answer {
  max-height: 0;
  overflow: hidden;
  background: var(--color-surface);
  padding: 0 15px;
  transition: max-height .4s ease, padding .3s ease;
}

.faq_answer.open {
  max-height: 500px;
  padding: 15px;
}

.faq_answer p {
  font-size: 18px;
  line-height: 1.6;
  margin: 0;
  color: var(--color-text-secondary);
}

/* ─────────────────────────────────── MOBILE ─── */
@media (max-width: 768px) {
  .faq_sec    { padding: 20px; }
  .faq_sec h2 { font-size: 26px; }
  .faq_question { font-size: 17px; }
  .faq_answer p { font-size: 16px; }
}
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.faq_question').forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      const answerId = btn.getAttribute('aria-controls');
      const answer   = answerId ? document.getElementById(answerId) : null;

      // Close all others
      document.querySelectorAll<HTMLButtonElement>('.faq_question').forEach(other => {
        if (other !== btn) {
          other.setAttribute('aria-expanded', 'false');
          const othId = other.getAttribute('aria-controls');
          if (othId) document.getElementById(othId)?.classList.remove('open');
        }
      });

      // Toggle this one
      btn.setAttribute('aria-expanded', String(!expanded));
      answer?.classList.toggle('open', !expanded);
    });
  });
</script>
