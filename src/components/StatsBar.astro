---
/**
 * src/components/StatsBar.astro
 * Horizontal row of numerical statistics / trust signals.
 */

interface Stat {
  value: string;
  label: string;
}

interface Props {
  stats?: Stat[];
}

const defaultStats: Stat[] = [
  { value: '500+',  label: 'Games Available'  },
  { value: '15min', label: 'Avg Withdrawal'   },
  { value: '24/7',  label: 'Live Support'     },
  { value: 'Fast',  label: 'Loading Speed'    },
];

const { stats = defaultStats } = Astro.props;
---

<section class="stats-bar" aria-label="Key stats">
  <div class="container stats-inner">
    {stats.map(({ value, label }) => (
      <div class="stat-card">
        <span class="stat-value">{value}</span>
        <span class="stat-label">{label}</span>
      </div>
    ))}
  </div>
</section>

<style>
.stats-bar {
  background: var(--page-bg, #0b1219);
  padding: 48px 0;
}

.stats-inner {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
}

.stat-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 32px 20px;
  background: var(--color-surface, #12121a);
  border: 1px solid rgba(255,255,255,.08);
  border-radius: 14px;
  min-height: 110px;
}

.stat-value {
  font-family: var(--font-family, sans-serif);
  font-size: clamp(1.6rem, 3vw, 2.2rem);
  font-weight: 700;
  color: #fff;
  line-height: 1;
  letter-spacing: -0.5px;
}

.stat-label {
  font-size: 0.9rem;
  color: rgba(255,255,255,.45);
  font-weight: 400;
  text-align: center;
  line-height: 1.3;
}

/* ── Mobile ── */
@media (max-width: 768px) {
  .stats-bar     { padding: 32px 0; }
  .stats-inner   { grid-template-columns: repeat(2, 1fr); gap: 12px; }
  .stat-card     { padding: 24px 16px; min-height: 90px; }
  .stat-value    { font-size: 1.5rem; }
  .stat-label    { font-size: 0.8rem; }
}

@media (max-width: 420px) {
  .stats-inner { grid-template-columns: repeat(2, 1fr); gap: 10px; }
  .stat-card   { padding: 20px 12px; }
}
</style>
