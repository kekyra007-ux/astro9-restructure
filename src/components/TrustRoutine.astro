---
/**
 * TrustRoutine.astro — Trust routine section with 4 numbered cards + callout
 *
 * Design:
 *   • Title
 *   • 2x2 grid of numbered cards with icon, title, description, CTA
 *   • Large gold callout box with icon, title, description, CTA
 *
 * Props:
 *   data  object  — trustRoutine data from locale JSON
 */

interface Card {
  number: number;
  icon: string;
  title: string;
  description: string;
  cta: string;
}

interface Props {
  data: {
    title: string;
    cards: Card[];
    calloutIcon: string;
    calloutTitle: string;
    calloutDescription: string;
    calloutCta: string;
  };
}

const { data } = Astro.props;
---

<section class="trust-routine">
  <div class="trust-routine__container">
    
    {/* Title */}
    <h2 class="trust-routine__title">{data.title}</h2>

    {/* Cards Grid */}
    <div class="trust-routine__cards">
      {data.cards.map((card) => (
        <div class="trust-routine__card">
        <div class="trust-routine__card-top">
  <div class="trust-routine__card-step">Step {card.number}</div>
</div>

<h3 class="trust-routine__card-title">{card.title}</h3>
<p class="trust-routine__card-description">{card.description}</p>
<a href="#" class="trust-routine__card-cta">{card.cta}</a>
        </div>
      ))}
    </div>

    {/* Callout Box */}
    <div class="trust-routine__callout">
<div class="trust-routine__callout-icon">
  <img src={data.calloutIcon} alt="" loading="lazy" />
</div>    <div class="trust-routine__callout-content">
        <h3 class="trust-routine__callout-title">{data.calloutTitle}</h3>
        <p class="trust-routine__callout-description">{data.calloutDescription}</p>
        <a href="#" class="trust-routine__callout-cta">{data.calloutCta}</a>
      </div>
    </div>

  </div>
</section>
<style>
.trust-routine {
  background: linear-gradient(180deg, #f8fafc 0%, #f3f6fb 100%);
  padding: 96px 20px;
}

.trust-routine__container {
  max-width: 1240px;
  margin: 0 auto;
  padding: 0 20px;
}

.trust-routine__title {
  margin: 0 auto 48px;
    font-size: clamp(1.5rem, 1.2rem + 1.6vw, 2rem);
    font-weight: 700;
    line-height: 1.02;
    letter-spacing: -0.045em;
  color: #0f172a;
  text-align: center;
  text-transform: none;
  text-wrap: balance;
}

/* Cards Grid */
.trust-routine__cards {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 22px;
  margin-bottom: 28px;
}

.trust-routine__card {
  position: relative;
  display: flex;
  flex-direction: column;
  min-height: 100%;
  padding: 28px 26px 24px;
  border-radius: 24px;
  background:
    linear-gradient(180deg, rgba(255,255,255,0.96) 0%, rgba(248,250,255,0.92) 100%);
  border: 1px solid rgba(148, 163, 184, 0.18);
  box-shadow:
    0 14px 30px rgba(15, 23, 42, 0.05),
    0 1px 0 rgba(255,255,255,0.82) inset;
  overflow: hidden;
  transition:
    transform 0.28s ease,
    box-shadow 0.28s ease,
    border-color 0.28s ease;
}

.trust-routine__card::before {
  content: "";
  position: absolute;
  inset: 0 0 auto 0;
  height: 3px;
  background: linear-gradient(90deg, #6366f1 0%, #818cf8 55%, #a5b4fc 100%);
}

.trust-routine__card:hover {
  transform: translateY(-4px);
  border-color: rgba(99, 102, 241, 0.22);
  box-shadow:
    0 20px 40px rgba(15, 23, 42, 0.08),
    0 1px 0 rgba(255,255,255,0.88) inset;
}

.trust-routine__card-top {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  margin-bottom: 14px;
}

.trust-routine__card-step {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 34px;
  padding: 0 12px;
  border-radius: 999px;
  background: rgba(99, 102, 241, 0.08);
  border: 1px solid rgba(99, 102, 241, 0.12);
  color: #4f46e5;
  font-size: 0.78rem;
  line-height: 1;
  font-weight: 800;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

.trust-routine__card-title {
  margin: 0 0 12px;
  font-size: clamp(1.05rem, 0.95rem + 0.25vw, 1.28rem);
  line-height: 1.12;
  font-weight: 700;
  letter-spacing: -0.03em;
  color: #0f172a;
  text-transform: none;
  text-wrap: balance;
}

.trust-routine__card-description {
  margin: 0 0 18px;
  font-size: 0.95rem;
  line-height: 1.68;
  color: #475569;
  max-width: 42ch;
}

.trust-routine__card-cta {
  margin-top: auto;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  width: fit-content;
  min-height: 42px;
  padding: 0 14px;
  border-radius: 12px;
  background: rgba(99, 102, 241, 0.06);
  border: 1px solid rgba(99, 102, 241, 0.1);
  color: #4f46e5;
  text-decoration: none;
  font-size: 0.82rem;
  font-weight: 700;
  letter-spacing: 0.02em;
  transition:
    background 0.28s ease,
    border-color 0.28s ease,
    transform 0.28s ease,
    color 0.28s ease;
}

.trust-routine__card-cta::after {
  content: "→";
  font-size: 0.95rem;
  line-height: 1;
}

.trust-routine__card-cta:hover {
  background: rgba(99, 102, 241, 0.1);
  border-color: rgba(99, 102, 241, 0.16);
  transform: translateY(-1px);
}

.trust-routine__card-cta::after {
  content: "→";
  font-size: 0.95rem;
  line-height: 1;
}

.trust-routine__card-cta:hover {
  background: rgba(99, 102, 241, 0.1);
  border-color: rgba(99, 102, 241, 0.16);
  transform: translateY(-1px);
}

.trust-routine__callout {
  position: relative;
  display: grid;

  grid-template-columns: 140px minmax(0, 720px);
  justify-content: space-between;

  align-items: center;
  column-gap: 32px;

  padding: 34px 32px;
  border-radius: 28px;

  background:
    linear-gradient(135deg, rgba(79, 70, 229, 0.96) 0%, rgba(99, 102, 241, 0.94) 52%, rgba(129, 140, 248, 0.92) 100%);

  box-shadow:
    0 24px 50px rgba(79, 70, 229, 0.2),
    0 1px 0 rgba(255,255,255,0.12) inset;

  overflow: hidden;
}

.trust-routine__callout::before {
  content: "";
  position: absolute;
  inset: auto -60px -80px auto;
  width: 240px;
  height: 240px;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
  filter: blur(10px);
}

.trust-routine__callout::after {
  content: "";
  position: absolute;
  inset: 0;
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: inherit;
  pointer-events: none;
}

.trust-routine__callout-icon {
  position: relative;
  z-index: 1;

  width: 248px;
  height: 248px;

  display: flex;
  align-items: center;
  justify-content: center;

  border-radius: 34px;

  background:
    linear-gradient(180deg, rgba(255,255,255,0.18) 0%, rgba(255,255,255,0.08) 100%);
  box-shadow:
    0 18px 34px rgba(15, 23, 42, 0.16),
    inset 0 1px 0 rgba(255,255,255,0.22);
}

.trust-routine__callout-icon::before {
  content: "";
  position: absolute;
  inset: 12px;
  border-radius: 26px;
  border: 1px solid rgba(255,255,255,0.08);
  pointer-events: none;
}

.trust-routine__callout-icon img {
  position: relative;
  z-index: 1;
  width: 205px;
  height: 205px;
  object-fit: contain;
  display: block;
  filter: drop-shadow(0 10px 14px rgba(15, 23, 42, 0.14));
}

.trust-routine__callout-content {
  position: relative;
  z-index: 1;
  min-width: 0;

  justify-self: end;
  width: 100%;

  display: flex;
  flex-direction: column;
  align-items: flex-end;   
  text-align: right;      
}
.trust-routine__callout-title {
  margin: 0 0 10px;
  font-size: clamp(1.45rem, 1.15rem + 0.8vw, 2.2rem);
  line-height: 1.02;
  font-weight: 800;
  letter-spacing: -0.03em;
  color: #ffffff;

  text-align: right;
}
.trust-routine__callout-description {
  margin: 0 0 18px;
  font-size: 0.97rem;
  line-height: 1.72;
  color: rgba(255, 255, 255, 0.82);

  text-align: right;
}

.trust-routine__callout-cta {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 46px;
  padding: 0 16px;
  border-radius: 14px;
  background: rgba(255,255,255,0.14);
  border: 1px solid rgba(255,255,255,0.12);
  color: #ffffff;
  text-decoration: none;
  font-size: 0.84rem;
  font-weight: 800;
  letter-spacing: 0.02em;
  transition:
    background 0.28s ease,
    transform 0.28s ease,
    border-color 0.28s ease;
}

.trust-routine__callout-cta::after {
  content: "→";
  margin-left: 8px;
  font-size: 0.95rem;
}

.trust-routine__callout-cta:hover {
  background: rgba(255,255,255,0.18);
  border-color: rgba(255,255,255,0.18);
  transform: translateY(-1px);
}


@media (max-width: 1400px) {
  .trust-routine__callout {
    grid-template-columns: 200px minmax(0, 1fr);
    column-gap: 28px;
    padding: 32px 28px;
  }

  .trust-routine__callout-icon {
    width: 200px;
    height: 200px;
    border-radius: 30px;
  }

  .trust-routine__callout-icon::before {
    inset: 10px;
    border-radius: 22px;
  }

  .trust-routine__callout-icon img {
    width: 158px;
    height: 158px;
  }

  .trust-routine__callout-title {
    font-size: clamp(1.4rem, 1.1rem + 0.9vw, 2rem);
  }

  .trust-routine__callout-description {
    font-size: 0.95rem;
    line-height: 1.68;
  }
}

@media (max-width: 1200px) {
  .trust-routine__callout {
    grid-template-columns: 168px minmax(0, 1fr);
    column-gap: 24px;
    padding: 28px 24px;
    border-radius: 24px;
  }

  .trust-routine__callout::before {
    width: 200px;
    height: 200px;
    right: -50px;
    bottom: -70px;
  }

  .trust-routine__callout-icon {
    width: 168px;
    height: 168px;
    border-radius: 26px;
  }

  .trust-routine__callout-icon::before {
    inset: 10px;
    border-radius: 18px;
  }

  .trust-routine__callout-icon img {
    width: 126px;
    height: 126px;
  }

  .trust-routine__callout-title {
    font-size: clamp(1.35rem, 1.05rem + 0.8vw, 1.85rem);
    line-height: 1.04;
  }

  .trust-routine__callout-description {
    font-size: 0.93rem;
    line-height: 1.65;
  }

  .trust-routine__callout-cta {
    min-height: 44px;
    padding: 0 15px;
    font-size: 0.82rem;
  }
}

@media (max-width: 992px) {
  .trust-routine__callout {
    grid-template-columns: 140px minmax(0, 1fr);
    column-gap: 20px;
    padding: 24px 20px;
    border-radius: 22px;
  }

  .trust-routine__callout-icon {
    width: 140px;
    height: 140px;
    border-radius: 22px;
  }

  .trust-routine__callout-icon::before {
    inset: 8px;
    border-radius: 16px;
  }

  .trust-routine__callout-icon img {
    width: 104px;
    height: 104px;
  }

  .trust-routine__callout-title {
    font-size: 1.7rem;
    line-height: 1.04;
  }

  .trust-routine__callout-description {
    font-size: 0.91rem;
    line-height: 1.62;
    margin-bottom: 16px;
  }

  .trust-routine__callout-cta {
    min-height: 42px;
    border-radius: 12px;
    padding: 0 14px;
  }
}

@media (max-width: 768px) {
  .trust-routine__callout {
    grid-template-columns: 1fr;
    justify-content: center;
    justify-items: center;
    row-gap: 18px;

    padding: 24px 18px;
    border-radius: 24px;
    text-align: center;
  }

  .trust-routine__callout::before {
    width: 180px;
    height: 180px;
    right: -40px;
    bottom: -60px;
  }

  .trust-routine__callout-icon {
    width: 128px;
    height: 128px;
    border-radius: 24px;
  }

  .trust-routine__callout-icon::before {
    inset: 8px;
    border-radius: 16px;
  }

  .trust-routine__callout-icon img {
    width: 96px;
    height: 96px;
  }

  .trust-routine__callout-content {
    justify-self: center;
    align-items: center;
    text-align: center;
    max-width: 100%;
  }

  .trust-routine__callout-title {
    margin: 0 0 10px;
    font-size: clamp(1.45rem, 1.15rem + 1vw, 1.9rem);
    line-height: 1.05;
    text-align: center;
  }

  .trust-routine__callout-description {
    margin: 0 0 16px;
    font-size: 0.92rem;
    line-height: 1.64;
    text-align: center;
    max-width: 100%;
  }

  .trust-routine__callout-cta {
    width: 100%;
    max-width: 360px;
    min-height: 46px;
    padding: 0 18px;
    font-size: 0.84rem;
  }
}

@media (max-width: 480px) {
  .trust-routine__callout {
    row-gap: 16px;
    padding: 20px 16px;
    border-radius: 20px;
  }

  .trust-routine__callout::before {
    width: 140px;
    height: 140px;
    right: -30px;
    bottom: -45px;
  }

  .trust-routine__callout-icon {
    width: 108px;
    height: 108px;
    border-radius: 20px;
  }

  .trust-routine__callout-icon::before {
    inset: 7px;
    border-radius: 14px;
  }

  .trust-routine__callout-icon img {
    width: 78px;
    height: 78px;
  }

  .trust-routine__callout-title {
    font-size: 1.55rem;
    line-height: 1.06;
  }

  .trust-routine__callout-description {
    font-size: 0.9rem;
    line-height: 1.58;
    margin-bottom: 14px;
  }

  .trust-routine__callout-cta {
    min-height: 44px;
    border-radius: 12px;
    font-size: 0.8rem;
    letter-spacing: 0.01em;
  }
}
@media (max-width: 1024px) {
  .trust-routine {
    padding: 72px 16px;
  }

  .trust-routine__title {
    margin-bottom: 38px;
  }

  .trust-routine__cards {
    gap: 18px;
    margin-bottom: 22px;
  }

  .trust-routine__card {
    padding: 24px 22px 22px;
    border-radius: 22px;
  }


}

/* Mobile */
@media (max-width: 768px) {
  .trust-routine {
    padding: 56px 12px;
  }

  .trust-routine__container {
    padding: 0 10px;
  }

  .trust-routine__title {
    max-width: 100%;
    margin-bottom: 28px;
    font-size: clamp(1.7rem, 1.3rem + 1.4vw, 2.2rem);
  }

  .trust-routine__cards {
    grid-template-columns: 1fr;
    gap: 14px;
    margin-bottom: 18px;
  }

  .trust-routine__card {
    padding: 22px 18px 18px;
    border-radius: 20px;
  }

  .trust-routine__card-header {
    gap: 12px;
    margin-bottom: 12px;
  }

  .trust-routine__card-number {
    min-width: 38px;
    height: 38px;
    font-size: 0.82rem;
  }

  .trust-routine__card-title {
    font-size: 1rem;
    line-height: 1.18;
  }

  .trust-routine__card-description {
    font-size: 0.9rem;
    line-height: 1.62;
    margin-bottom: 16px;
  }

  .trust-routine__card-cta {
    width: 100%;
    justify-content: center;
  }



}
</style>