---
interface Row {
  label: string;
  text: string;
}

interface Props {
  heading: string;
  description: string;
  depositCard: {
    tag: string;
    subtitle: string;
    heading: string;
    rows: Row[];
    cta: string;
  };
  ctaHref: string;
}

const { heading, description, depositCard, ctaHref } = Astro.props;
---

<section class="bonus-intro">
  <div class="bonus-intro__inner">
    <h2 class="bonus-intro__heading">{heading}</h2>
    <p class="bonus-intro__desc">{description}</p>

    <div class="bonus-intro__card">
      <span class="bonus-intro__tag">{depositCard.tag}</span>
      <p class="bonus-intro__subtitle">{depositCard.subtitle}</p>
      <h3 class="bonus-intro__card-heading">{depositCard.heading}</h3>
      <div class="bonus-intro__rows">
        {depositCard.rows.map((row) => (
          <div class="bonus-intro__row">
            <span class="bonus-intro__row-label">{row.label}</span>
            <span class="bonus-intro__row-text">{row.text}</span>
          </div>
        ))}
      </div>
      <a href={ctaHref} class="bonus-intro__cta">{depositCard.cta}</a>
    </div>
  </div>
</section>

<style>
  .bonus-intro {
    background: var(--color-bg);
    padding: 5.5rem 0 4.5rem;
  }

  .bonus-intro__inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--container-pad);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.75rem;
  }

  .bonus-intro__heading {
     margin: 0 auto 20px;
    font-size: clamp(1.5rem, 1.2rem + 1.6vw, 2rem);
    font-weight: 700;
    line-height: 1.02;
    letter-spacing: -0.045em;
  color: #0f172a;
  text-align: center;
  text-transform: none;
  text-wrap: balance;
  }

  .bonus-intro__desc {
    max-width: 70ch;
    margin: 0;
    font-size: 1rem;
    line-height: 1.72;
    text-align: center;
    text-wrap: pretty;
    color: color-mix(in srgb, var(--color-text) 90%, white);
  }

  .bonus-intro__card {
    position: relative;
    width: 100%;
    max-width: var(--container-max);
    margin-top: 0.5rem;
    padding: 2rem;
    border-radius: 30px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.92) 0%, rgba(255, 255, 255, 0.86) 100%);
    border: 1px solid color-mix(in srgb, var(--color-border) 78%, white);
    box-shadow:
      0 18px 40px rgba(15, 23, 42, 0.06),
      0 1px 0 rgba(255, 255, 255, 0.82) inset;
    backdrop-filter: blur(10px);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .bonus-intro__card::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 4px;
    background: linear-gradient(
      90deg,
      #6366f1 0%,
      #818cf8 45%,
      #a5b4fc 100%
    );
  }

  .bonus-intro__tag {
    display: inline-flex;
    align-self: flex-start;
    align-items: center;
    justify-content: center;
    min-height: 2rem;
    margin: 0 0 1rem;
    padding: 0.42rem 0.85rem;
    border-radius: 999px;
    background: rgba(99, 102, 241, 0.1);
    border: 1px solid rgba(99, 102, 241, 0.14);
    color: #4f46e5;
    font-size: 0.74rem;
    font-weight: 700;
    line-height: 1;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .bonus-intro__subtitle {
    margin: 0 0 0.65rem;
    font-size: 0.84rem;
    font-weight: 700;
    line-height: 1.35;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-text) 68%, white);
  }

  .bonus-intro__card-heading {
    max-width: 16ch;
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 1.15rem + 1vw, 2.35rem);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.035em;
    text-wrap: balance;
    color: var(--color-title);
  }

  .bonus-intro__rows {
    display: flex;
    flex-direction: column;
    margin-top: 1.75rem;
    border-top: 1px solid rgba(15, 23, 42, 0.08);
  }

  .bonus-intro__row {
    display: grid;
    grid-template-columns: minmax(160px, 190px) 1fr;
    gap: 1.5rem;
    align-items: start;
    padding: 1rem 0;
    border-bottom: 1px solid rgba(15, 23, 42, 0.08);
  }

  .bonus-intro__row-label {
    font-size: 0.84rem;
    font-weight: 700;
    line-height: 1.45;
    letter-spacing: 0.01em;
    color: color-mix(in srgb, var(--color-title) 88%, white);
  }

  .bonus-intro__row-text {
    font-size: 0.95rem;
    font-weight: 500;
    line-height: 1.65;
    text-align: left;
    color: var(--color-text);
  }

  .bonus-intro__cta {
    min-height: 3.35rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    align-self: flex-start;
    margin-top: 1.5rem;
    padding: 0.9rem 1.4rem;
    border-radius: 16px;
    background: linear-gradient(
      180deg,
      #5b61f6 0%,
      #4f46e5 100%
    );
    box-shadow:
      0 12px 22px rgba(79, 70, 229, 0.18),
      0 1px 0 rgba(255, 255, 255, 0.18) inset;
    color: #fff;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 800;
    line-height: 1;
    letter-spacing: 0.02em;
    transition:
      transform var(--transition),
      box-shadow var(--transition),
      filter var(--transition);
  }

  .bonus-intro__cta:hover {
    transform: translateY(-1px);
    filter: brightness(1.02);
    box-shadow:
      0 16px 28px rgba(79, 70, 229, 0.22),
      0 1px 0 rgba(255, 255, 255, 0.2) inset;
  }

  @media (max-width: 900px) {
    .bonus-intro {
      padding: 4.75rem 0 4rem;
    }

    .bonus-intro__inner {
      gap: 1.4rem;
    }

    .bonus-intro__card {
      max-width: 100%;
      padding: 1.6rem;
      border-radius: 24px;
    }

    .bonus-intro__card-heading {
      max-width: 100%;
    }

    .bonus-intro__row {
      grid-template-columns: 150px 1fr;
      gap: 1.1rem;
    }
  }

  @media (max-width: 640px) {
    .bonus-intro {
      padding: 4rem 0 3.5rem;
    }

    .bonus-intro__heading {
      max-width: 100%;
      font-size: clamp(1.55rem, 1.2rem + 1.8vw, 2.2rem);
    }

    .bonus-intro__desc {
      font-size: 0.95rem;
      line-height: 1.65;
    }

    .bonus-intro__card {
      padding: 1.35rem;
      border-radius: 22px;
    }

    .bonus-intro__tag {
      margin-bottom: 0.85rem;
    }

    .bonus-intro__subtitle {
      margin-bottom: 0.55rem;
      font-size: 0.78rem;
    }

    .bonus-intro__card-heading {
      font-size: 1.45rem;
      line-height: 1.12;
    }

    .bonus-intro__rows {
      margin-top: 1.35rem;
    }

    .bonus-intro__row {
      grid-template-columns: 1fr;
      gap: 0.35rem;
      padding: 0.9rem 0;
    }

    .bonus-intro__row-label {
      font-size: 0.8rem;
    }

    .bonus-intro__row-text {
      font-size: 0.92rem;
      line-height: 1.6;
    }

    .bonus-intro__cta {
      width: 100%;
      align-self: stretch;
      margin-top: 1.25rem;
    }
  }
</style>
