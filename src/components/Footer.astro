---
/**
 * Footer.astro — Site footer with 3-column info, social links, callout, and copyright
 */

interface Column {
  title: string;
  description: string;
}

interface SocialLink {
  src: string;
  alt: string;
}

interface Props {
  data?: {
    columns?: Column[];
    socialLinks?: SocialLink[];
    calloutTitle?: string;
    calloutDescription?: string;
    calloutCta?: string;
    copyrightText?: string;
  };
}

const { data = {} } = Astro.props;

// Provide defaults for all data properties
const {
  columns = [],
  socialLinks = [],
  calloutTitle = '',
  calloutDescription = '',
  calloutCta = '',
  copyrightText = ''
} = data;
---

<footer class="footer">
  <div class="footer__container">

    {/* 3-Column Info */}
    {columns && columns.length > 0 && (
      <div class="footer__columns">
        {columns.map((col, i) => (
          <div class="footer__column">
            <h3 class="footer__column-title">{col.title}</h3>
            <p class="footer__column-description">{col.description}</p>
       
          </div>
        ))}
      </div>
    )}

    {/* Social Icons */}
    {socialLinks && socialLinks.length > 0 && (
      <div class="footer__socials">
        {socialLinks.map((s) => (
          <a href="#" class="footer__social-link" title={s.alt} aria-label={s.alt}>
            <img src={s.src} alt={s.alt} width="22" height="22" />
          </a>
        ))}
      </div>
    )}

    {/* Callout Box */}
    {calloutTitle && (
      <div class="footer__callout">
        <h3 class="footer__callout-title">{calloutTitle}</h3>
        <p class="footer__callout-description">{calloutDescription}</p>
        <a href="#" class="footer__callout-cta">{calloutCta}</a>
      </div>
    )}

    {/* Copyright */}
    {copyrightText && (
      <p class="footer__copyright">{copyrightText}</p>
    )}

  </div>
</footer>
<style>
.footer {
  background: #0F172A;
  color: #E2E8F0;
  padding: 64px 20px 40px;
  border-top: none;
}

.footer__container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 20px;
}

/* 3-Column Layout */
.footer__columns {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 40px;
  margin-bottom: 40px;
}

.footer__column-title {
  font-size: 13px;
  font-weight: 600;
  color: #FFFFFF;
  margin: 0 0 14px;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.footer__column-description {
  font-size: 13px;
  line-height: 1.75;
  color: #94A3B8;
  margin: 0;
}

/* Disclaimer + Gamble icons in last column */
.footer__trust-icons {
  display: flex;
  gap: 12px;
  margin-top: 16px;
  align-items: center;
}

.footer__trust-icon {
  width: 40px;
  height: 40px;
  object-fit: contain;
  opacity: 0.85;
  transition: opacity 0.3s ease;
}

.footer__trust-icon:hover {
  opacity: 1;
}

/* Social Icons */
.footer__socials {
  display: flex;
  gap: 16px;
  margin-bottom: 40px;
  padding-bottom: 40px;
  border-bottom: 1px solid rgba(99,102,241, 0.2);
  justify-content: center;
  flex-wrap: wrap;
}

.footer__social-link {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  background: rgba(255,255,255,0.06);
  border-radius: 8px;
  border: 1px solid rgba(255,255,255,0.1);
  text-decoration: none;
  transition: all 0.18s ease;
}

.footer__social-link:hover {
  background: rgba(99,102,241, 0.2);
  border-color: #6366F1;
  transform: translateY(-2px);
}

.footer__social-link img {
  width: 20px;
  height: 20px;
  object-fit: contain;
  filter: brightness(0) invert(1);
  opacity: 0.7;
  transition: opacity 0.18s ease;
}

.footer__social-link:hover img {
  opacity: 1;
  filter: brightness(0) invert(1);
}

/* Callout Box */
.footer__callout {
  background: rgba(99,102,241, 0.08);
  border: 1px solid rgba(99,102,241, 0.25);
  border-radius: 12px;
  padding: 32px 24px;
  margin-bottom: 32px;
  text-align: center;
}

.footer__callout-title {
  font-size: 18px;
  font-weight: 700;
  color: #A5B4FC;
  margin: 0 0 10px;
  letter-spacing: -0.01em;
}

.footer__callout-description {
  font-size: 14px;
  line-height: 1.65;
  color: #94A3B8;
  margin: 0 0 18px;
}

.footer__callout-cta {
  display: inline-block;
  padding: 10px 28px;
  background: linear-gradient(135deg, #6366F1 0%, #4F46E5 100%);
  color: #FFFFFF;
  border-radius: 24px;
  font-size: 12px;
  font-weight: 900;
  text-decoration: none;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  transition: all 0.3s ease;
}

.footer__callout-cta:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 12px rgba(99,102,241, 0.3);
}

/* Social border */
.footer__socials {
  border-bottom-color: rgba(255,255,255,0.08) !important;
}

/* Copyright */
.footer__copyright {
  font-size: 12px;
  line-height: 1.6;
  color: #475569;
  margin: 0;
  text-align: center;
}

/* ─────────────────────────────────────────────────────── TABLET ─── */
@media (max-width: 1024px) {
  .footer {
    padding: 40px 16px 30px;
  }

  .footer__columns {
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  .footer__callout {
    padding: 24px 20px;
  }

  .footer__callout-title {
    font-size: 18px;
  }
}

/* ─────────────────────────────────────────────────────── MOBILE ─── */
@media (max-width: 768px) {
  .footer {
    padding: 30px 12px 20px;
  }

  .footer__columns {
    grid-template-columns: 1fr;
    gap: 20px;
  }

  .footer__column-title {
    font-size: 14px;
  }

  .footer__column-description {
    font-size: 12px;
  }

  .footer__trust-icons {
    margin-top: 12px;
  }

  .footer__trust-icon {
    width: 32px;
    height: 32px;
  }

  .footer__socials {
    margin-bottom: 24px;
    padding-bottom: 24px;
    gap: 12px;
  }

  .footer__social-link {
    width: 40px;
    height: 40px;
  }

  .footer__social-link img {
    width: 20px;
    height: 20px;
  }

  .footer__callout {
    padding: 20px 14px;
  }

  .footer__callout-title {
    font-size: 16px;
  }

  .footer__callout-description {
    font-size: 13px;
  }

  .footer__callout-cta {
    padding: 8px 24px;
    font-size: 11px;
  }
}

@media (max-width: 480px) {
  .footer__column-title {
    font-size: 13px;
  }

  .footer__column-description {
    font-size: 11px;
  }

  .footer__callout-title {
    font-size: 14px;
  }

  .footer__callout-description {
    font-size: 12px;
  }

  .footer__copyright {
    font-size: 11px;
  }
}
</style>
