---
interface Props {
  heading: string;
  items: string[];
}

const { heading, items } = Astro.props;
---

<section class="bonus-terms">
  <div class="bonus-terms__inner">
    <div class="bonus-terms__card">
      <h2 class="bonus-terms__heading">{heading}</h2>
      <ul class="bonus-terms__list">
        {items.map((item) => (
          <li class="bonus-terms__item">{item}</li>
        ))}
      </ul>
    </div>
  </div>
</section>
<style>
  .bonus-terms {
    background: var(--color-bg);
    padding: 0 0 5.5rem;
  }

  .bonus-terms__inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--container-pad);
  }

  .bonus-terms__card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    padding: 2.2rem 2rem;
    border-radius: 28px;
    background:
      linear-gradient(180deg, rgba(255,255,255,0.92) 0%, rgba(248,250,255,0.88) 100%);
    border: 1px solid color-mix(in srgb, var(--color-border) 75%, white);
    box-shadow:
      0 16px 40px rgba(15, 23, 42, 0.06),
      0 1px 0 rgba(255,255,255,0.8) inset;
    backdrop-filter: blur(10px);
    overflow: hidden;
  }



  .bonus-terms__heading {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 1rem + 0.6vw, 1.45rem);
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--color-title);
  }

  .bonus-terms__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  .bonus-terms__item {
    position: relative;
    display: grid;
    grid-template-columns: 18px 1fr;
    gap: 0.75rem;
    align-items: start;
    padding: 0.8rem 0;
    font-size: 0.93rem;
    line-height: 1.65;
    color: color-mix(in srgb, var(--color-text) 88%, white);
  }

  /* разделители между пунктами */
  .bonus-terms__item:not(:last-child) {
    border-bottom: 1px solid rgba(15, 23, 42, 0.06);
  }

  /* аккуратный маркер вместо "•" */
  .bonus-terms__item::before {
    content: "";
    width: 6px;
    height: 6px;
    margin-top: 0.55rem;
    border-radius: 50%;
    background: #6366F1;
    box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.12);
  }

  @media (max-width: 640px) {
    .bonus-terms {
      padding: 0 0 4.5rem;
    }

    .bonus-terms__card {
      padding: 1.5rem 1.35rem;
      border-radius: 22px;
      gap: 1.4rem;
    }

    .bonus-terms__heading {
      font-size: 1.05rem;
    }

    .bonus-terms__item {
      font-size: 0.9rem;
      padding: 0.7rem 0;
      gap: 0.6rem;
    }
  }
</style>