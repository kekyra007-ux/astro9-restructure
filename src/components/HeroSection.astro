---
/**
 * HeroSection.astro — Reusable hero component for all pages (except home)
 *
 * Design:
 *   • Full-width section with background
 *   • Top: 4 tag buttons (icon + label)
 *   • Title (large, gold)
 *   • Subtitle/Description
 *   • Tags/Keywords at bottom
 *   • CTA button (gold gradient)
 *
 * Props:
 *   lang        string   — 'en' or 'tl'
 *   title       string   — main heading
 *   description string   — subtitle/description
 *   tags        array    — keyword tags
 *   ctaText     string   — button label
 *   ctaHref     string   — button URL
 *   topButtons  array    — [{icon, label, href}]
 *   bgSrc       string   — background image
 */

interface TopButton {
  icon: string;
  label: string;
  href?: string;
}

interface Props {
  lang?: string;
  title?: string;
  description?: string;
  tags?: string[];
  ctaText?: string;
  ctaHref?: string;
  topButtons?: TopButton[];
  bgSrc?: string;
}

const {
  lang = 'en',
  title = 'OKABCPH',
  description = 'Official platform for Philippines users',
  tags = [],
  ctaText = 'GET STARTED',
  ctaHref = '#',
  topButtons = [],
  bgSrc = '/img/hero-banner.avif',
} = Astro.props;

const ref = import.meta.env.PUBLIC_REF ?? '#';
const resolvedHref = ctaHref ?? ref;
---

<section class="hero-section" aria-label="Page hero section">
  <!-- Background image -->
  <img
    class="hero-section__bg"
    src={bgSrc}
    alt=""
    role="presentation"
    width="1440"
    height="600"
    loading="eager"
    decoding="async"
    fetchpriority="high"
  />

  <!-- Content container -->
  <div class="hero-section__container">
    <!-- Top buttons -->
    {topButtons && topButtons.length > 0 && (
      <div class="hero-section__top-buttons">
        {topButtons.map((btn) => (
          <a href={btn.href || ref} class="hero-section__top-btn">
            <span class="hero-section__top-btn-icon">{btn.icon}</span>
            <span class="hero-section__top-btn-label">{btn.label}</span>
          </a>
        ))}
      </div>
    )}

    <!-- Main content -->
    <div class="hero-section__content">
      <h1 class="hero-section__title">{title}</h1>
      {description && <p class="hero-section__description">{description}</p>}

      <!-- Tags -->
      {tags && tags.length > 0 && (
        <div class="hero-section__tags">
          {tags.map((tag) => (
            <span class="hero-section__tag">{tag}</span>
          ))}
        </div>
      )}

      <!-- CTA Button -->
      <a href={resolvedHref} class="hero-section__cta btn btn--gold">
        {ctaText}
      </a>
    </div>
  </div>
</section>
<style>
.hero-section {
  position: relative;
  width: 100%;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 96px 24px 88px;
  text-align: center;
  background:
    radial-gradient(circle at 50% 0%, rgba(99, 102, 241, 0.12) 0%, rgba(99, 102, 241, 0) 32%),
    radial-gradient(circle at 15% 20%, rgba(129, 140, 248, 0.08) 0%, rgba(129, 140, 248, 0) 24%),
    linear-gradient(180deg, #ffffff 0%, #f8faff 48%, #f2f5ff 100%);
}

.hero-section::before {
  content: "";
  position: absolute;
  top: -120px;
  left: -120px;
  width: 320px;
  height: 320px;
  border-radius: 50%;
  background: rgba(99, 102, 241, 0.08);
  filter: blur(80px);
  pointer-events: none;
}

.hero-section::after {
  content: "";
  position: absolute;
  right: -120px;
  bottom: -140px;
  width: 360px;
  height: 360px;
  border-radius: 50%;
  background: rgba(79, 70, 229, 0.08);
  filter: blur(90px);
  pointer-events: none;
}

.hero-section__bg {
  display: none;
}

.hero-section__container {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 30px;
  max-width: 1200px;
  width: 100%;
}

.hero-section__top-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  justify-content: center;
  max-width: 1200px;
}

.hero-section__top-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  min-height: 40px;
  padding: 0 18px;
  background: rgba(255, 255, 255, 0.86);
  color: var(--color-primary);
  border: 1px solid rgba(99, 102, 241, 0.14);
  border-radius: 999px;
  font-weight: 650;
  font-size: 0.82rem;
  text-decoration: none;
  letter-spacing: 0.01em;
  box-shadow:
    0 8px 20px rgba(15, 23, 42, 0.05),
    inset 0 1px 0 rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(12px);
  transition:
    transform var(--transition),
    box-shadow var(--transition),
    border-color var(--transition),
    background var(--transition),
    color var(--transition);
}

.hero-section__top-btn:hover {
  transform: translateY(-2px);
  background: rgba(99, 102, 241, 0.08);
  color: var(--color-primary-hover);
  border-color: rgba(99, 102, 241, 0.24);
  box-shadow:
    0 14px 28px rgba(79, 70, 229, 0.12),
    inset 0 1px 0 rgba(255, 255, 255, 0.72);
}

.hero-section__top-btn-icon {
  font-size: 0.95rem;
  line-height: 1;
}

.hero-section__top-btn-label {
  letter-spacing: 0.01em;
}

.hero-section__content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18px;
}

.hero-section__title {
  margin: 0;
  font-family: var(--font-display);
  font-size: clamp(2.4rem, 5vw, 5rem);
  font-weight: 800;
  line-height: 1;
  letter-spacing: -0.065em;
  color: var(--color-text);
  text-wrap: balance;
}

.hero-section__description {
  margin: 0;
  max-width: 64ch;
  font-size: clamp(1rem, 1.35vw, 1.12rem);
  font-weight: 400;
  line-height: 1.78;
  color: var(--color-text-secondary);
  text-wrap: pretty;
}

.hero-section__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  justify-content: center;
  max-width: 720px;
  margin-top: 2px;
}

.hero-section__tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 34px;
  padding: 0 14px;
  background: rgba(255, 255, 255, 0.78);
  border: 1px solid rgba(226, 232, 240, 0.92);
  border-radius: 999px;
  font-size: 0.76rem;
  font-weight: 600;
  color: var(--color-text-secondary);
  box-shadow: 0 4px 14px rgba(15, 23, 42, 0.04);
  transition:
    transform var(--transition),
    border-color var(--transition),
    background var(--transition),
    color var(--transition);
}

.hero-section__tag:hover {
  transform: translateY(-1px);
  border-color: rgba(99, 102, 241, 0.18);
  color: var(--color-primary);
  background: rgba(99, 102, 241, 0.06);
}

.hero-section__cta {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 54px;
  padding: 0 34px;
  margin-top: 8px;
  background: linear-gradient(180deg, var(--color-three) 0%, var(--color-four) 100%);
  color: var(--color-two);
  border: none;
  border-radius: 14px;
  font-size: 0.94rem;
  font-weight: 700;
  letter-spacing: 0.02em;
  text-decoration: none;
  cursor: pointer;
  box-shadow:
    0 14px 28px rgba(79, 70, 229, 0.22),
    inset 0 1px 0 rgba(255, 255, 255, 0.18);
  transition:
    transform var(--transition),
    box-shadow var(--transition),
    filter var(--transition);
}

.hero-section__cta:hover {
  transform: translateY(-2px);
  filter: brightness(1.02);
  box-shadow:
    0 18px 34px rgba(79, 70, 229, 0.28),
    inset 0 1px 0 rgba(255, 255, 255, 0.18);
}

@media (max-width: 1024px) {
  .hero-section {
    min-height: 560px;
    padding: 84px 20px 76px;
  }

  .hero-section__container {
    max-width: 860px;
    gap: 26px;
  }

  .hero-section__title {
    max-width: 13ch;
    font-size: clamp(2.2rem, 5vw, 4.1rem);
  }

  .hero-section__description {
    max-width: 58ch;
  }
}

@media (max-width: 640px) {
  .hero-section {
    min-height: auto;
    padding: 60px 16px 48px;
  }

  .hero-section__container {
    gap: 20px;
  }

  .hero-section__top-buttons {
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }

  .hero-section__top-btn {
    width: 100%;
    max-width: 330px;
    justify-content: center;
    min-height: 42px;
    padding: 0 16px;
    font-size: 0.82rem;
  }

  .hero-section__top-btn-icon {
    font-size: 1rem;
  }

  .hero-section__content {
    gap: 14px;
  }

  .hero-section__title {
    max-width: 100%;
    font-size: clamp(2rem, 9vw, 3rem);
    line-height: 0.94;
    letter-spacing: -0.055em;
  }

  .hero-section__description {
    max-width: 100%;
    font-size: 0.95rem;
    line-height: 1.65;
  }

  .hero-section__tags {
    gap: 8px;
    justify-content: center;
  }

  .hero-section__tag {
    min-height: 34px;
    padding: 0 12px;
    font-size: 0.73rem;
  }

  .hero-section__cta {
    width: 100%;
    max-width: 360px;
    min-height: 54px;
    padding: 0 24px;
    font-size: 0.92rem;
  }
}

@media (max-width: 480px) {
  .hero-section {
    padding: 52px 14px 42px;
  }

  .hero-section__container {
    gap: 18px;
  }

  .hero-section__top-buttons {
    gap: 8px;
  }

  .hero-section__top-btn {
    max-width: 100%;
    min-height: 40px;
    padding: 0 14px;
    font-size: 0.78rem;
    border-radius: 999px;
  }

  .hero-section__top-btn-label {
    line-height: 1.2;
  }

  .hero-section__title {
    font-size: clamp(1.85rem, 10vw, 2.55rem);
    line-height: 0.95;
    letter-spacing: -0.05em;
  }

  .hero-section__description {
    font-size: 0.92rem;
    line-height: 1.62;
  }

  .hero-section__tags {
    gap: 8px 6px;
  }

  .hero-section__tag {
    min-height: 32px;
    padding: 0 10px;
    font-size: 0.7rem;
  }

  .hero-section__cta {
    max-width: 100%;
    min-height: 52px;
    font-size: 0.88rem;
    padding: 0 18px;
    border-radius: 12px;
  }
}

@media (max-width: 380px) {
  .hero-section {
    padding: 48px 12px 38px;
  }

  .hero-section__title {
    font-size: 1.72rem;
  }

  .hero-section__description {
    font-size: 0.9rem;
  }

  .hero-section__top-btn {
    font-size: 0.74rem;
  }

  .hero-section__tag {
    font-size: 0.68rem;
  }

  .hero-section__cta {
    font-size: 0.84rem;
  }
}
</style>