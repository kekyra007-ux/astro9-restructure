---
interface WhyCard {
  title: string;
  text: string;
}

interface Props {
  heading: string;
  cards: WhyCard[];
  cta: {
    heading: string;
    description: string;
    buttons: string[];
    btnText: string;
  };
  ctaHref: string;
}

const { heading, cards, cta, ctaHref } = Astro.props;
---

<section class="casino-why">
  <div class="casino-why__inner">
    <h2 class="casino-why__heading">{heading}</h2>

    <div class="casino-why__grid">
      {cards.map((card) => (
        <div class="casino-why__card">
          <h3 class="casino-why__card-title">{card.title}</h3>
          <p class="casino-why__card-text">{card.text}</p>
        </div>
      ))}
    </div>

    <div class="casino-why__cta">
      <h2 class="casino-why__cta-heading">{cta.heading}</h2>
      <p class="casino-why__cta-desc">{cta.description}</p>
      <div class="casino-why__pills">
        {cta.buttons.map((btn) => (
          <a href={ctaHref} class="casino-why__pill">{btn}</a>
        ))}
      </div>
      <a href={ctaHref} class="casino-why__btn">{cta.btnText}</a>
    </div>
  </div>
</section>

<style>
  .casino-why {
    background: var(--color-bg);
    padding: 5rem 0;
  }

  .casino-why__inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--container-pad);
  }

  .casino-why__heading {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3.5vw, 2.4rem);
    font-weight: 900;
    color: var(--color-primary);
    text-align: center;
    text-transform: uppercase;
    line-height: 1.2;
    margin-bottom: 2.5rem;
  }

  .casino-why__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    margin-bottom: 5rem;
  }

  .casino-why__card {
    background: var(--color-surface);
    border: 1px solid rgba(99,102,241,0.2);
    border-radius: var(--radius-lg);
    padding: 2rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    text-align: center;
    transition: border-color var(--transition);
  }

  .casino-why__card:hover {
    border-color: rgba(99,102,241,0.45);
  }

  .casino-why__card-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1.3;
    margin: 0;
  }

  .casino-why__card-text {
    font-size: 0.87rem;
    color: rgba(255,255,255,0.65);
    line-height: 1.65;
    margin: 0;
  }

  /* CTA block */
  .casino-why__cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    text-align: center;
  }

  .casino-why__cta-heading {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 3vw, 2.2rem);
    font-weight: 900;
    color: var(--color-primary);
    line-height: 1.2;
    margin: 0;
  }

  .casino-why__cta-desc {
    font-size: 0.95rem;
    font-weight: 600;
    color: rgba(255,255,255,0.75);
    line-height: 1.65;
    max-width: 700px;
    margin: 0;
  }

  .casino-why__pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }

  .casino-why__pill {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1.25rem;
    border-radius: 999px;
    border: 1px solid rgba(15,23,42,0.08);
    background: rgba(255,255,255,0.04);
    color: rgba(255,255,255,0.75);
    font-size: 0.83rem;
    text-decoration: none;
    white-space: nowrap;
    transition: all var(--transition);
  }

  .casino-why__pill:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .casino-why__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.85rem 3rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #818CF8 0%, #c88a00 100%);
    color: #1a1200;
    font-size: 0.85rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    box-shadow: 0 4px 20px rgba(99,102,241,0.25);
    transition: opacity var(--transition), transform var(--transition);
  }

  .casino-why__btn:hover {
    opacity: 0.9;
    transform: translateY(-2px);
  }

  @media (max-width: 640px) {
    .casino-why__grid {
      grid-template-columns: 1fr;
    }

    .casino-why__btn {
      align-self: stretch;
    }
  }
</style>
