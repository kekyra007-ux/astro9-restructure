# ── Required by generator ────────────────────────────────────────────
# Copy this file to .env and fill in the values before running npm run build

# Brand name (used in titles, archive filename, etc.)
PUBLIC_BRAND=OKABCPH

# Full domain WITH https:// and WITHOUT trailing slash
PUBLIC_DOMAIN=https://okabcph.com

# Contact / support email
PUBLIC_EMAIL=

# Contact phone number
PUBLIC_PHONE=

# Main CTA / affiliate link (registration page)
PUBLIC_REF=https://okabcph.com/register

# App download link (if no app — same as PUBLIC_REF)
PUBLIC_APP=https://okabcph.com/register
